# --- LLM Settings ---
# MSI Stealth 14 AI Studio (RTX 4070 Laptop 8GB + 64GB RAM) 向け推奨設定
# num_gpu: GPUに乗せるレイヤー数（14B=28〜35、7B=32でフルGPU）
# num_thread: CPUスレッド数（Core Ultra 9 185H は12〜16推奨）
# num_ctx: コンテキスト長（小さいほど速い・VRAMに優しい）
OLLAMA_NUM_GPU=28
OLLAMA_NUM_THREAD=12
OLLAMA_NUM_CTX=1024
LITELLM_MODEL=deepseek-r1:latest
LITELLM_PROVIDER=ollama
LLM_TIMEOUT=60
MAX_HISTORY=40

# 会話履歴として保持する最大履歴数
MAX_HISTORY=40

# 呼び出しワード（複数指定する場合はカンマ区切り）
WAKE_WORD_ENABLED=False
WAKE_WORD=えーあい,AI,あい

# personaファイルのパス
PERSONA_FILE=./data/persona.txt

#YOLOのモデルセット
YOLO_MODEL_PATH=./data/base.pt

# --- OCR Settings ---
PYTESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Audio Settings ---
# デバイス名は部分一致で検索されます（例: "Voicemeeter Out A1" など）
# 指定がない（空の）場合は AUDIO_INPUT_DEVICE_INDEX が使用されます（未設定の場合、既定のデバイス）
AUDIO_INPUT_DEVICE_NAME="マイク配列 (デジタルマイク向けインテル® スマート・サウンド・テクノロジー)"
AUDIO_INPUT_DEVICE_INDEX=14

# 出力側も同様に部分一致で検索されます
AUDIO_OUTPUT_DEVICE_NAME="スピーカー"
AUDIO_OUTPUT_DEVICE_INDEX=16

# STT (Faster-Whisper) のモデルサイズ (tiny, base, small, medium, large-v3 など)
STT_MODEL_SIZE=large-v3

# MeCabの辞書パス
MECAB_IPADIC=C:\MeCab\dic\ipadic
MECAB_NEOLOGD=C:\MeCab\dic\NEologd/NEologd.20200910-u.dic

# STM → LTM 固定化設定
STM_MAX_WORD_LEN   = 2       # STMに入れる最小文字数
STM_SENTENCE_MAX   = 30      # STM文の最大長
STM_EXPIRE_MIN     = 30      # STM忘却タイムアウト（分）
STM_TO_LTM_WEIGHT  = 3       # LTMに昇格する閾値
LTM_DECAY_RATE     = 0.02    # LTM減衰率（/日）
LTM_DECAY_LIMIT    = 0.2     # この信頼度以下で削除
LTM_LOAD_LIMIT     = 5       # 取得するLTM件数

# GPT-SoVITS-v2pro設定
GPT_SOVITS_URL=http://127.0.0.1:9874
GPT_SOVITS_REF_AUDIO=ref.wav
GPT_SOVITS_TEXT_LANG=ja
GPT_SOVITS_PROMPT_LANG=ja

